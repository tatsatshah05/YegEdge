# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit secrets.

# ---------------------------------------------------------------------------
# Anthropic API (for the trading agent runtime — NOT Claude Code)
# Get from: https://console.anthropic.com/ → Settings → API Keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER

# Model selection (override defaults if needed)
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001
CLAUDE_MODEL_REVIEW=claude-opus-4-6

# Hard monthly cap in INR — agent stops calling Claude if exceeded
MAX_MONTHLY_API_SPEND_INR=1500

# ---------------------------------------------------------------------------
# Broker — Upstox (default)
# Get from: https://upstox.com/developer/apps
# ---------------------------------------------------------------------------
BROKER=upstox                       # upstox | dhan | kite
UPSTOX_API_KEY=PLACEHOLDER
UPSTOX_API_SECRET=PLACEHOLDER
UPSTOX_REDIRECT_URI=http://localhost:3000

# Daily access token (regenerated each morning after TOTP login)
# Leave empty; the morning login flow populates this.
UPSTOX_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Broker — Dhan (alternative)
# ---------------------------------------------------------------------------
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Broker — Zerodha Kite Connect (alternative)
# ---------------------------------------------------------------------------
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Trading mode
# ---------------------------------------------------------------------------
# CRITICAL: Live trading is DISABLED by default. Do not flip to true
# without completing the docs/live_readiness.md checklist.
LIVE_TRADING_ENABLED=false

# Paper trading session counter (auto-incremented). Used to enforce 60-session
# minimum before live can be enabled.
PAPER_SESSIONS_COMPLETED=0

# Starting capital for paper trading (INR)
PAPER_STARTING_CAPITAL=83000

# ---------------------------------------------------------------------------
# Telegram alerts (optional but recommended)
# ---------------------------------------------------------------------------
# 1. Talk to @BotFather on Telegram, create a bot, get TOKEN
# 2. Talk to @userinfobot to get your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite path (relative to project root)
JOURNAL_DB_PATH=./data/journal.db

# Parquet cache root
PARQUET_CACHE_DIR=./data/cache

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                      # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json                     # json | console
LOG_DIR=./logs

# ---------------------------------------------------------------------------
# Optional: Sentry error tracking
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Deployment (set on VPS only)
# ---------------------------------------------------------------------------
DEPLOYMENT_ENV=development          # development | paper-vps | live
STATIC_IP=                          # VPS static IP for SEBI compliance check
